{
  "manifest_version": 3,
  "name": "LinkedIn No Easy Apply",
  "version": "1.1.0",
  "description": "Hide LinkedIn job cards labeled Easy Apply and support resume-based autofill.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "LinkedIn No Easy Apply",
    "default_popup": "popup.html"
  }
}
